{
  "name": "orchestragrant",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter=@orchestragrant/web dev",
    "build": "pnpm --filter=@orchestragrant/web build",
    "typecheck": "pnpm --filter=@orchestragrant/web typecheck && pnpm --filter=@orchestragrant/types typecheck",
    "lint": "pnpm --filter=@orchestragrant/web lint",
    "test:unit": "pnpm --filter=@orchestragrant/web test:unit",
    "test:e2e": "pnpm --filter=@orchestragrant/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "next": "15.0.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "typescript": "^5.6.3"
  }
}
