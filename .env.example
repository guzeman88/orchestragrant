# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://orchestragrant:localdev@localhost:5432/orchestragrant
DATABASE_URL_SYNC=postgresql://orchestragrant:localdev@localhost:5432/orchestragrant

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 4096
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=orchestragrant-documents-local
SES_FROM_ADDRESS=noreply@orchestragrant.com

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLAMAPARSE_API_KEY=llx-...

# ─── External APIs ─────────────────────────────────────────────────────────────
GRANTS_GOV_API_KEY=
CANDID_CLIENT_ID=
CANDID_CLIENT_SECRET=

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...

# ─── App Config ────────────────────────────────────────────────────────────────
ENV=development
DEBUG=true
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_SENTRY_DSN=
